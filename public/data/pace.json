    "skill_level_definitions": {
      "novice": "Has just started running or runs very occasionally. Slower than 95% of runners. Equivalent to bottom 5th percentile.",
      "beginner": "Has been running regularly for up to 6 months. Faster than ~20% of runners. Roughly 20th percentile.",
      "intermediate": "Has been running consistently for 1-2+ years with structured training. Faster than ~50% of runners. Roughly 50th percentile.",
      "advanced": "Trains seriously with a structured program, typically 3-5+ years of experience. Faster than ~80% of runners. Roughly 80th percentile.",
      "elite": "Competitive or semi-professional level. Faster than ~95% of runners. Roughly 95th percentile or above."
    },
